# Copialo a .env.local y completá los valores reales.
# .env.local está ignorado por git — nunca se commitea.

# === MongoDB ===
# 1. Atlas → Cluster → Connect → Drivers → copiar string
# 2. Reemplazar <password> por la password real del DB user
# 3. Agregar el nombre de la database antes del "?"
MONGODB_URI=mongodb+srv://finanzas_app:TU_PASSWORD@cluster0.xxxxx.mongodb.net/finanzas-familia?retryWrites=true&w=majority

# === NextAuth ===
# Generar con:  openssl rand -base64 32
NEXTAUTH_SECRET=PEGAR_RESULTADO_DE_openssl_rand_base64_32

# Cambiar a la URL de producción de Vercel cuando deployes
NEXTAUTH_URL=http://localhost:3000

AUTH_TRUST_HOST=true
