# MongoDB Atlas connection string
# Formato: mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/finanzas-familia?retryWrites=true&w=majority
MONGODB_URI=

# NextAuth: generar con `openssl rand -base64 32`
NEXTAUTH_SECRET=REEMPLAZAR_CON_openssl_rand_base64_32

# URL absoluta de la app
# Local: http://localhost:3000
# Producción: https://<tu-proyecto>.vercel.app
NEXTAUTH_URL=http://localhost:3000

# AUTH_TRUST_HOST debe ser true en Vercel para que NextAuth resuelva el host
AUTH_TRUST_HOST=true
